import sys
import yaml
import asyncio
from pathlib import Path

from langgraph.graph import StateGraph, START, END
from langgraph.checkpoint.memory import MemorySaver

from src.config.chat_agent_models import (
    WorkflowState,
    ExtractorOutput,
    ValidatorOutput,
    TechQuestionsOutput,
    FinalStoryOutput,
)
from src.integrations.llm_client import get_llm_client

_PROMPTS_FILE = Path(__file__).resolve().parents[1] / "domain" / "prompts" / "grooming_agent.yaml"

def _load_prompts(file_path: Path) -> dict:
    if not file_path.exists():
        sys.exit(1)
    try:
        with open(file_path, "r", encoding="utf-8-sig") as f:
            return yaml.safe_load(f)
    except Exception:
        sys.exit(1)

PROMPTS = _load_prompts(_PROMPTS_FILE)
llm = get_llm_client()

async def phase0_extract(state: WorkflowState) -> dict:
    if state.get("who"):
        return {}

    sys_prompt = PROMPTS["extractor"]["system"]
    result = await asyncio.to_thread(llm.query, sys_prompt,
    f"Raw input: {state['raw_input']}", ExtractorOutput)

    missing = [k for k in ["who", "what", "why"] if not getattr(result, k)]

    return {
        "who": result.who, "what": result.what, "why": result.why,
        "ac_evidence": getattr(result, "ac_evidence", None),
        "missing_fields": missing
    }

async def phase1_lock(state: WorkflowState) -> dict:
    missing = state.get("missing_fields", [])
    if not missing:
        return {}

    target = missing[0]
    retries = state.get("phase1_retries", 0)

    if retries >= 3:
        return {"is_aborted": True, "abort_reason":
        f"System could not clarify '{target}' after 3 attempts."}

    rejection = state.get("last_rejection_reason")
    prompt_msg = f"[Invalid Input]: {rejection}\nPlease clarify {target}:" \
    if rejection else f"Please describe the {target}:"

    user_val = (state.get("user_injected_response") or "").strip()
    if not user_val:
        return {
            "action_required": True,
            "action_prompt": prompt_msg,
        }

    sys_prompt = PROMPTS["validator"]["system"].format(field=target)
    result = await asyncio.to_thread(llm.query, sys_prompt, f"User provided: {user_val}", ValidatorOutput)

    if result.is_valid:
        return {
            target: result.normalized_value, "missing_fields": missing[1:],
            "phase1_retries": 0, "last_rejection_reason": None,
            "action_required": False, "action_prompt": None,
            "user_injected_response": None,
        }

    return {
        "phase1_retries": retries + 1,
        "last_rejection_reason": result.rejection_reason,
        "user_injected_response": None,
    }

async def phase2_tech_lead(state: WorkflowState) -> dict:
    if state.get("pending_questions") or state.get("total_tech_questions", 0) > 0:
        return {}

    sys_prompt = PROMPTS["tech_lead"]["system"].format(what=state["what"], why=state["why"])
    result = await asyncio.to_thread(llm.query, sys_prompt, "Review and generate technical questions.", TechQuestionsOutput)

    return {"pending_questions": result.questions, "total_tech_questions": len(result.questions)}

async def phase2_ask_questions(state: WorkflowState) -> dict:
    questions = state.get("pending_questions", [])
    if not questions:
        return {}

    total = state.get("total_tech_questions", 0)
    current_idx = (total - len(questions)) + 1
    current_q = questions[0]

    prompt_msg = f"[Tech Lead - Q {current_idx}/{total}]:\n{current_q}\n(Type 'skip' to bypass)"
    user_answer_raw = (state.get("user_injected_response") or "").strip()
    if not user_answer_raw:
        return {
            "action_required": True,
            "action_prompt": prompt_msg,
        }

    user_answer = user_answer_raw.lower()

    if user_answer == "skip":
        return {
            "pending_questions": questions[1:],
            "action_required": False,
            "action_prompt": None,
            "user_injected_response": None,
        }

    sys_prompt = PROMPTS["inline_validator"]["system"].format(question=current_q, answer=user_answer)
    result = await asyncio.to_thread(llm.query, sys_prompt, f"Evaluate answer: {user_answer}", ValidatorOutput)

    new_notes = list(state.get("tech_notes", []))
    if result.is_valid and result.normalized_value:
        new_notes.append(f"Constraint derived from '{current_q}': {result.normalized_value}")

    return {
        "pending_questions": questions[1:],
        "tech_notes": new_notes,
        "action_required": False,
        "action_prompt": None,
        "user_injected_response": None,
    }

async def phase3_synthesize(state: WorkflowState) -> dict:
    tech_notes_str = "\n".join(state.get("tech_notes", []))
    sys_prompt = PROMPTS["agile_coach"]["system"].format(
        who=state["who"], what=state["what"], why=state["why"], 
        tech_notes=tech_notes_str, ac_evidence=state.get("ac_evidence", ""),
        feedback=state.get("feedback_raw", "")
    )

    result = await asyncio.to_thread(llm.query, sys_prompt, "Generate final Jira story.", FinalStoryOutput)
    return {"final_story": result.story, "feedback_raw": None}

async def phase3_feedback(state: WorkflowState) -> dict:
    retries = state.get("feedback_retries", 0)
    if retries >= 3:
        return {"is_complete": True}

    prompt_msg = f"[Agile Coach Output]:\n{state['final_story']}\n\nType 'confirm' to accept, or provide feedback:"
    user_input_raw = (state.get("user_injected_response") or "").strip()
    if not user_input_raw:
        return {
            "action_required": True,
            "action_prompt": prompt_msg,
        }

    user_input = user_input_raw.lower()

    if user_input == "confirm":
        return {
            "is_complete": True,
            "action_required": False,
            "action_prompt": None,
            "user_injected_response": None,
        }

    return {
        "feedback_raw": user_input,
        "feedback_retries": retries + 1,
        "action_required": False,
        "action_prompt": None,
        "user_injected_response": None,
    }

def _route_phase0(state: WorkflowState) -> str:
    return "phase1_lock" if state.get("missing_fields") else "phase2_tech_lead"

def _route_phase1(state: WorkflowState) -> str:
    if state.get("is_aborted"):
        return END
    if state.get("action_required"):
        return END
    return "phase1_lock" if state.get("missing_fields") else "phase2_tech_lead"

def _route_phase2_ask(state: WorkflowState) -> str:
    if state.get("action_required"):
        return END
    return "phase2_ask_questions" if state.get("pending_questions") else "phase3_synthesize"

def _route_phase3_feedback(state: WorkflowState) -> str:
    if state.get("action_required"):
        return END
    return END if state.get("is_complete") else "phase3_synthesize"

builder = StateGraph(WorkflowState)

builder.add_node("phase0_extract", phase0_extract)
builder.add_node("phase1_lock", phase1_lock)
builder.add_node("phase2_tech_lead", phase2_tech_lead)
builder.add_node("phase2_ask_questions", phase2_ask_questions)
builder.add_node("phase3_synthesize", phase3_synthesize)
builder.add_node("phase3_feedback", phase3_feedback)

builder.add_edge(START, "phase0_extract")
builder.add_conditional_edges("phase0_extract", _route_phase0)
builder.add_conditional_edges("phase1_lock", _route_phase1)
builder.add_edge("phase2_tech_lead", "phase2_ask_questions")
builder.add_conditional_edges("phase2_ask_questions", _route_phase2_ask)
builder.add_edge("phase3_synthesize", "phase3_feedback")
builder.add_conditional_edges("phase3_feedback", _route_phase3_feedback)

memory = MemorySaver()
graph = builder.compile(checkpointer=memory)
